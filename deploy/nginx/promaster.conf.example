## Production Nginx — МаБибип (HTTP(S) + WebSocket)
## Скопируйте в sites-available или conf.d, подставьте домен, сертификаты и upstream.
##
## Upstream (релиз):
## - 127.0.0.1:8000 — Gunicorn, config.wsgi:application
## - 127.0.0.1:8001 — Uvicorn, config.asgi:application (обязателен для /ws/)
##
## Docker Compose: см. deploy/nginx/docker-frontend.conf и docs/DEPLOY-NGINX-PRODUCTION.md
## (прокси на web:8000 и asgi:8001 по имени сервисов).
##
## Nginx terminates TLS

map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

limit_req_zone $binary_remote_addr zone=login_limit:10m rate=10r/m;
limit_req_zone $binary_remote_addr zone=api_limit:10m rate=30r/s;
limit_req_zone $binary_remote_addr zone=webhook_limit:10m rate=10r/s;

server {
    listen 80;
    server_name mabibip.ru www.mabibip.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name mabibip.ru www.mabibip.ru;

    ssl_certificate     /etc/letsencrypt/live/mabibip.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mabibip.ru/privkey.pem;

    # Security headers (defense in depth; app also sets some)
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
    add_header Cross-Origin-Opener-Policy same-origin always;
    add_header X-Frame-Options DENY always;

    # HSTS (enable only when HTTPS is stable on your domain)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    client_max_body_size 10m;

    # Сжатие ответов (HTML/CSS/JS/JSON/SVG) — меньше трафика на мобильных сетях
    gzip on;
    gzip_comp_level 5;
    gzip_min_length 256;
    gzip_vary on;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        application/xml
        image/svg+xml;

    # Real IP (set your proxy chain if any)
    # real_ip_header X-Forwarded-For;
    # set_real_ip_from 127.0.0.1;

    location /static/ {
        alias /var/www/mabibip/static/;
        access_log off;
        expires 30d;
    }

    location /media/ {
        alias /var/www/mabibip/media/;
        access_log off;
        expires 7d;
    }

    # Login/register hardening (bruteforce / bot throttling)
    location ~* ^/accounts/(login|register)/ {
        limit_req zone=login_limit burst=5 nodelay;
        proxy_pass http://127.0.0.1:8000;
        include /etc/nginx/proxy_params;
        proxy_set_header X-Forwarded-Proto https;
    }

    # Payment webhook endpoint: signature-verified in app, but still protect from flood
    location = /billing/yookassa/webhook/ {
        limit_req zone=webhook_limit burst=20 nodelay;
        proxy_pass http://127.0.0.1:8000;
        include /etc/nginx/proxy_params;
        proxy_set_header X-Forwarded-Proto https;
    }

    # WebSocket (Django Channels) — только ASGI, не Gunicorn
    location /ws/ {
        limit_req zone=api_limit burst=50 nodelay;
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Остальной трафик — WSGI (Gunicorn)
    location / {
        limit_req zone=api_limit burst=100 nodelay;
        proxy_pass http://127.0.0.1:8000;
        include /etc/nginx/proxy_params;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
    }
}

