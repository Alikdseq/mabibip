# Скопируйте в .env и заполните. Файл .env не коммитить.

# --- Docker (docker compose up) ---
# Скопируйте пример или задайте в .env рядом с docker-compose.yml:
# WEB_PORT=8000
#   SECRET_KEY=<случайная строка 50+ символов>
#   CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
#   SITE_BASE_URL=http://127.0.0.1:8000
# Город по умолчанию в шапке (District.city_label). По умолчанию Владикавказ.
#   VISITOR_DEFAULT_CITY_LABEL=Владикавказ
# Режим одного города (MVP Владикавказ): только этот город в списке и без переключателя при одном пункте.
# Отключить ограничение (мультигород): APP_FOCUS_CITY_LABEL=
#   APP_FOCUS_CITY_LABEL=Владикавказ
#   VISITOR_CITY_GUESS_FROM_IP=0
# Суперпользователь (см. также комментарии в docker-compose.yml):
#   docker compose run --rm web python manage.py createsuperuser
#   docker compose run --rm --entrypoint "" web python manage.py createsuperuser

# Каталог: 1 = все активные СТО в каталоге без проверки оплаты Basic (режим «пока бесплатно для всех»).
# 0 = снова скрывать Basic без оплаты / с просрочкой subscription_paid_until.
# CATALOG_BYPASS_SUBSCRIPTION=1

# Общие
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-generate-with-get_random_secret_key
# В config.settings.base читаются DEBUG и ALLOWED_HOSTS; dev/prod переопределяют при необходимости
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# База данных: по умолчанию локально — SpatiaLite (db.sqlite3). Для PostGIS задайте URL.
DATABASE_URL=
# Пример PostgreSQL + PostGIS (docker compose использует образ postgis/postgis):
# DATABASE_URL=postgres://user:password@127.0.0.1:5432/promaster

# Фаза F2: геокодирование адреса СТО (Nominatim, фиксированный host в коде)
# GEOCODING_ENABLED=0
# GEOCODING_USER_AGENT=MaBibipCatalog/1.0 (ваш контакт для OSM)
# STATION_CARD_CACHE_TTL=900

# Аналитика: карта новых СТО на /secure-admin/dashboard/ (опционально)
# YANDEX_MAPS_API_KEY=

# Pytest + GeoDjango: в Docker без libspatialite задайте PostGIS (сервис db из compose):
# TEST_DATABASE_URL=postgres://promaster:promaster@127.0.0.1:5432/promaster
# Локально с установленным GDAL/SpatiaLite можно не задавать — будет test_gis.sqlite3.

# Фаза F3: Redis (удержание слотов), Celery (docker compose: redis, celery-worker, celery-beat)
# REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# SLOT_HOLD_TTL_SECONDS=900
# SLOT_GENERATION_DAYS_AHEAD=7
#
# WebSocket в браузере: по умолчанию берётся тот же хост, что и страница (и порт :8001 при странице :8000).
# Если публичный URL ведёт только на WSGI (один ngrok / один порт), задайте базу до ASGI (второй туннель) или
# настройте прокси /ws/ → uvicorn. Пример второго туннеля: wss://xxxx.ngrok-free.app
# CHANNELS_WS_CLIENT_BASE_URL=wss://xxxx.ngrok-free.app
#
# Релиз: Nginx перед Docker (единый порт, /ws/ → asgi) — см. docs/DEPLOY-NGINX-PRODUCTION.md
# NGINX_HTTP_PORT=80
# За TLS-прокси до контейнеров (HTTP внутри): для docker.settings
# USE_X_FORWARDED_HOST=1
# SECURE_PROXY_SSL_HEADER=1

# Базовый URL сайта: письма, JSON-LD, canonical/robots/sitemap (без слэша в конце).
# SITE_BASE_URL=https://mabibip.ru
# После деплоя синхронизировать django.contrib.sites с этим доменом (sitemap при отсутствии SITE_BASE_URL):
#   python manage.py sync_site_domain

# ЮKassa: пока выключено (вебхук извне вернёт 403). После настройки кабинета ЮKassa включите и задайте секрет вебхука.
# YOOKASSA_ENABLED=0
# YOOKASSA_WEBHOOK_SECRET=

# Продакшен (config.settings.prod)
# DEBUG=False
# ALLOWED_HOSTS=mabibip.ru,www.mabibip.ru
# CSRF_TRUSTED_ORIGINS=https://mabibip.ru,https://www.mabibip.ru

# Почта: dev — console (см. config.settings.dev); prod — при EMAIL_HOST включается SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@mabibip.ru

# Фаза F0: сохранять IP при фиксации согласия с документами (только по согласованию с юристом)
# LEGAL_CONSENT_STORE_IP=false

# После деплоя загрузите юридические тексты из docs/legal/:
# python manage.py seed_legal_documents --version-label=1.0 --effective-now

# --- Фаза F1: SMS, reCAPTCHA v3, django-axes ---
# SMS_BACKEND=console
# SMSRU_API_ID=
# SMSAERO_EMAIL=
# SMSAERO_API_KEY=
# reCAPTCHA v3 (invisible, token-based; no checkbox widget)
# Публичный ключ (site key) можно хранить в репозитории, но секретный ключ — НЕЛЬЗЯ.
# Возьмите значения в Google reCAPTCHA admin. Для локальной разработки домены: localhost, 127.0.0.1
RECAPTCHA_SITE_KEY=6Lf3MLksAAAAABq_qCI8EgHrMpevUpsKvd3uSFxm
# RECAPTCHA_SECRET_KEY=<<<вставьте сюда секретный ключ (не коммитить)>>>
# Версия: v3 (по умолчанию, невидимая) или v2 (галочка)
# RECAPTCHA_VERSION=v3
# RECAPTCHA_MIN_SCORE=0.5
# Для локальных тестов в settings.tests: RECAPTCHA_SKIP=True
# AXES_ENABLED=1
# AXES_FAILURE_LIMIT=5
# AXES_COOLOFF_MINUTES=15
# --- VK / VK ID (виджет One Tap + django-allauth) ---
# Создайте приложение в https://id.vk.ru/business/go — redirect URI для виджета (побайтно как в кабинете VK):
#   https://<ваш-домен>/accounts/vk/login/callback/
# Если видите invalid_request / redirect_uri is missing or invalid:
#   - задайте VK_ID_REDIRECT_URI ровно тем же URL, что в кабинете VK; или
#   - SITE_BASE_URL=https://<домен> без слэша в конце и с тем же хостом, с которого открывают сайт (без www / с www).
# Дополнительно для классического OAuth allauth:
#   https://<ваш-домен>/oauth/vk/login/callback/
# VK_CLIENT_ID=
# VK_CLIENT_SECRET=
# VK_ID_REDIRECT_URI=

# За reverse-proxy задайте SECURE_PROXY_SSL_HEADER и корректный client IP для axes.
